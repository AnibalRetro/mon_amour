rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Temporary permissive rules for Mon Amour while the admin panel
    // is operating without Firebase Authentication. Tighten before production.
    match /models/{modelId} {
      allow read, write: if true;
    }

    match /leads/{leadId} {
      allow read, write: if true;
    }

    match /reservations/{reservationId} {
      allow read, write: if true;
    }

    match /users/{userId} {
      allow read, write: if true;
    }
  }
}
